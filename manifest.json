{
    "manifest_version": 3,
    "name": "Iris",
    "version": "1.0",
    "permissions": ["activeTab", "scripting"],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["https://edstem.org/*"],
            "js": ["dist/content.js"]
        }
    ]
}
